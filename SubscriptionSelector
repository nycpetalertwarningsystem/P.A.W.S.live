/**
 * Subscription Selector Component
 * Displays available subscription plans and handles checkout
 * First 10K subscriptions are FREE
 */

import React, { useState, useEffect } from "react";
import { Button } from "@/components/ui/button";
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import { trpc } from "@/lib/trpc";
import { toast } from "sonner";

type PlanType = "pet_profile" | "medical_records" | "behavioral_challenges";

interface SubscriptionSelectorProps {
  onSuccess?: () => void;
}

const PLANS = [
  {
    id: "pet_profile" as PlanType,
    name: "Pet Profile",
    description: "Store and manage unlimited pet profiles with emergency information",
    price: 27.39,
    icon: "🐾",
    features: [
      "Unlimited pet profiles",
      "Emergency contact information",
      "Pet photos and documents",
      "Access for emergency responders",
      "Lifetime membership for first 10K members"
    ],
    highlight: false,
  },
  {
    id: "medical_records" as PlanType,
    name: "Medical Records",
    description: "Track comprehensive medical history for your pets",
    price: 27.39,
    icon: "⚕️",
    features: [
      "Medical history tracking",
      "Medication management",
      "Allergy documentation",
      "Surgery and procedure records",
      "Vaccination tracking",
      "Vet visit history",
      "Emergency medical access"
    ],
    highlight: true,
  },
  {
    id: "behavioral_challenges" as PlanType,
    name: "Behavioral & Social Challenges",
    description: "Document and manage behavioral and social challenges",
    price: 27.39,
    icon: "🧠",
    features: [
      "Behavioral issue documentation",
      "Anxiety tracking",
      "Aggression management",
      "Fear and phobia records",
      "Reactivity tracking",
      "Separation anxiety documentation",
      "Management strategies and tips"
    ],
    highlight: false,
  },
];

export function SubscriptionSelector({ onSuccess }: SubscriptionSelectorProps) {
  const [selectedPlan, setSelectedPlan] = useState<PlanType>("pet_profile");
  const [isLoading, setIsLoading] = useState(false);
  const [isFreeAvailable, setIsFreeAvailable] = useState(false);
  // toast is imported from sonner
  
  const createCheckout = trpc.stripe.createCheckout.useMutation();
  const checkFreeAvailable = trpc.membership.isFreeAvailable.useQuery();
  const getRemainingFree = trpc.membership.getRemainingFreeSlots.useQuery();

  useEffect(() => {
    if (checkFreeAvailable.data !== undefined) {
      setIsFreeAvailable(checkFreeAvailable.data);
    }
  }, [checkFreeAvailable.data]);

  const claimFreeSlot = trpc.membership.claimFreeSlot.useMutation();

  const handleCheckout = async () => {
    try {
      setIsLoading(true);
      
      if (isFreeAvailable) {
        // For free tier, claim the free slot
        await claimFreeSlot.mutateAsync();
        toast({
          title: "🎉 Welcome to P.A.W.S.!",
          description: "Your free membership is now active. You're one of the first 10,000!",
        });
        onSuccess?.();
      } else {
        // For paid tier, create Stripe checkout
        const result = await createCheckout.mutateAsync({
          planType: selectedPlan,
          origin: window.location.origin,
        });

        if (result.checkoutUrl) {
          window.open(result.checkoutUrl, "_blank");
          toast({
            title: "Redirecting to checkout",
            description: "Opening Stripe checkout in a new tab...",
          });
          onSuccess?.();
        }
      }
    } catch (error) {
      console.error("Checkout error:", error);
      toast({
        title: "Checkout failed",
        description: "Failed to create checkout session. Please try again.",
        variant: "destructive",
      });
    } finally {
      setIsLoading(false);
    }
  };

  const remainingSlots = getRemainingFree.data || 0;
  const slotsExhausted = remainingSlots === 0;

  return (
    <div className="w-full space-y-8">
      {/* Free Tier Banner */}
      {isFreeAvailable && !slotsExhausted && (
        <Card className="border-green-500 bg-green-50">
          <CardContent className="pt-6">
            <div className="flex items-center justify-between">
              <div>
                <h3 className="font-bold text-green-900">🎉 FREE Membership Available!</h3>
                <p className="text-sm text-green-800">
                  You're eligible for a FREE membership! Only {remainingSlots.toLocaleString()} slots remaining.
                </p>
              </div>
              <Badge className="bg-green-600 hover:bg-green-700">LIMITED TIME</Badge>
            </div>
          </CardContent>
        </Card>
      )}

      {/* Slots Exhausted Banner */}
      {slotsExhausted && (
        <Card className="border-orange-500 bg-orange-50">
          <CardContent className="pt-6">
            <p className="text-sm text-orange-900">
              ⚠️ Free membership slots have been exhausted. Premium pricing now applies.
            </p>
          </CardContent>
        </Card>
      )}

      {/* Plans Grid */}
      <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
        {PLANS.map((plan) => (
          <Card
            key={plan.id}
            className={`relative cursor-pointer transition-all ${
              selectedPlan === plan.id
                ? "ring-2 ring-orange-500 shadow-lg"
                : "hover:shadow-md"
            } ${plan.highlight ? "md:scale-105" : ""}`}
            onClick={() => setSelectedPlan(plan.id)}
          >
            {plan.highlight && (
              <div className="absolute top-0 right-0 bg-orange-500 text-white px-3 py-1 rounded-bl-lg text-xs font-semibold">
                POPULAR
              </div>
            )}
            <CardHeader>
              <div className="text-4xl mb-2">{plan.icon}</div>
              <CardTitle className="text-xl">{plan.name}</CardTitle>
              <CardDescription>{plan.description}</CardDescription>
            </CardHeader>
            <CardContent className="space-y-4">
              {/* Price */}
              <div className="border-t pt-4">
                {isFreeAvailable && !slotsExhausted ? (
                  <>
                    <div className="text-3xl font-bold text-green-600">FREE</div>
                    <div className="text-xs text-green-600">First 10K members</div>
                    <div className="text-xs text-gray-500 line-through">
                      Regular: ${plan.price.toFixed(2)}/year
                    </div>
                  </>
                ) : (
                  <>
                    <div className="text-3xl font-bold text-orange-600">
                      ${plan.price.toFixed(2)}
                    </div>
                    <div className="text-sm text-gray-600">per year</div>
                  </>
                )}
              </div>

              {/* Features */}
              <ul className="space-y-2">
                {plan.features.map((feature, idx) => (
                  <li key={idx} className="flex items-start gap-2 text-sm">
                    <span className="text-orange-500 font-bold">✓</span>
                    <span>{feature}</span>
                  </li>
                ))}
              </ul>

              {/* Selection Indicator */}
              <div className="pt-2">
                {selectedPlan === plan.id && (
                  <Badge className="w-full justify-center bg-orange-500 hover:bg-orange-600">
                    Selected
                  </Badge>
                )}
              </div>
            </CardContent>
          </Card>
        ))}
      </div>

      {/* What's Covered */}
      <Card>
        <CardHeader>
          <CardTitle>What Your Subscription Covers</CardTitle>
        </CardHeader>
        <CardContent>
          <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4">
            {[
              { icon: "🖥️", title: "Storage Units & Servers", description: "Secure cloud infrastructure for your pet data" },
              { icon: "⚙️", title: "Hardware & Software", description: "Enterprise-grade systems and maintenance" },
              { icon: "👨‍💼", title: "System Analyst", description: "Professional system monitoring and optimization" },
              { icon: "☁️", title: "Cloud Developer", description: "Continuous platform development and improvements" },
              { icon: "🔒", title: "Cybersecurity", description: "24/7 security monitoring and data protection" },
            ].map((item, idx) => (
              <div key={idx} className="text-center space-y-2">
                <div className="text-3xl">{item.icon}</div>
                <h4 className="font-semibold text-sm">{item.title}</h4>
                <p className="text-xs text-gray-600">{item.description}</p>
              </div>
            ))}
          </div>
        </CardContent>
      </Card>

      {/* Checkout Button */}
      <div className="flex justify-center">
        <Button
          size="lg"
          onClick={handleCheckout}
          disabled={isLoading}
          className={`px-8 py-6 text-lg ${
            isFreeAvailable && !slotsExhausted
              ? "bg-green-600 hover:bg-green-700"
              : "bg-orange-600 hover:bg-orange-700"
          } text-white`}
        >
          {isLoading ? "Processing..." : isFreeAvailable && !slotsExhausted ? "Claim FREE Membership" : "Proceed to Checkout"}
        </Button>
      </div>

      {/* Info Text */}
      <div className="text-center text-sm text-gray-600 space-y-2">
        {isFreeAvailable && !slotsExhausted ? (
          <>
            <p>🎁 No credit card required for FREE membership</p>
            <p>✅ Instant activation after signup</p>
            <p>📧 You'll receive a confirmation email</p>
          </>
        ) : (
          <>
            <p>💳 Secure payment powered by Stripe</p>
            <p>🔒 Your payment information is encrypted and secure</p>
            <p>📧 You'll receive a confirmation email after purchase</p>
          </>
        )}
      </div>
    </div>
  );
}
