/**
 * Payment History Component
 * Displays user's payment and subscription history
 */

import React from "react";
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import { trpc } from "@/lib/trpc";

export function PaymentHistory() {
  const paymentHistoryQuery = trpc.stripe.getPaymentHistory.useQuery();

  if (paymentHistoryQuery.isLoading) {
    return (
      <Card>
        <CardHeader>
          <CardTitle>Payment History</CardTitle>
        </CardHeader>
        <CardContent>
          <div className="text-center text-gray-500">Loading payment history...</div>
        </CardContent>
      </Card>
    );
  }

  const payments = paymentHistoryQuery.data || [];

  return (
    <Card>
      <CardHeader>
        <CardTitle>Payment History</CardTitle>
        <CardDescription>Your subscription and payment records</CardDescription>
      </CardHeader>
      <CardContent>
        {payments.length === 0 ? (
          <div className="text-center py-8 text-gray-500">
            <p>No payments yet</p>
          </div>
        ) : (
          <div className="space-y-4">
            {payments.map((payment: any, idx: number) => (
              <div key={idx} className="border-b pb-4 last:border-b-0">
                <div className="flex items-start justify-between">
                  <div>
                    <p className="font-semibold text-gray-900">
                      {payment.planType ? payment.planType.replace(/_/g, " ").toUpperCase() : "Subscription"}
                    </p>
                    <p className="text-sm text-gray-600">
                      {new Date(payment.createdAt).toLocaleDateString()}
                    </p>
                  </div>
                  <div className="text-right">
                    <p className="font-bold text-lg text-orange-600">
                      ${(payment.amount / 100).toFixed(2)}
                    </p>
                    <Badge
                      className={`mt-2 ${
                        payment.status === "succeeded"
                          ? "bg-green-100 text-green-800"
                          : payment.status === "failed"
                          ? "bg-red-100 text-red-800"
                          : "bg-yellow-100 text-yellow-800"
                      }`}
                    >
                      {payment.status}
                    </Badge>
                  </div>
                </div>
              </div>
            ))}
          </div>
        )}
      </CardContent>
    </Card>
  );
}
